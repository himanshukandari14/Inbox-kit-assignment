# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies (root and nested packages)
node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js — match anywhere (e.g. client/.next/, not only repo root)
.next/
out/

# production / compiled output
build/
dist/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env — ignore secrets; keep checked-in examples
.env
.env.*
!.env.example
!.env*.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
